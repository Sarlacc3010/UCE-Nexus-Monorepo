# Normalize all text files to LF in the repo; Git handles conversion on checkout per OS.
* text=auto eol=lf

# Explicit binary types (avoid any accidental line-ending mangling)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.ttf binary
*.woff binary
*.woff2 binary
