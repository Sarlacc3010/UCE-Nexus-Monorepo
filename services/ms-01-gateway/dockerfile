# ==========================================
# Etapa 1: Construcción (Builder)
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copiar archivos de definición de dependencias
COPY package*.json ./

# Instalar todas las dependencias (incluyendo devDependencies para compilar)
RUN npm ci

# Copiar el código fuente y la configuración
COPY . .

# Compilar el código TypeScript a JavaScript
RUN npm run build

# ==========================================
# Etapa 2: Imagen de Producción (Runner)
# ==========================================
FROM node:20-alpine AS runner

# Establecer entorno de producción
ENV NODE_ENV=production
WORKDIR /app

# Copiar archivos de definición de dependencias
COPY package*.json ./

# Instalar únicamente dependencias de producción (seguridad y ligereza)
RUN npm ci --omit=dev && npm cache clean --force

# Copiar el código compilado desde la etapa de construcción
COPY --from=builder /app/dist ./dist

# Copiar archivos estáticos o contratos gRPC necesarios en runtime
# NOTA: index.js compilado se encuentra en /dist, por lo que el .proto debe estar en la misma carpeta
COPY --from=builder /app/src/booking.proto ./dist/

# Cambiar el propietario de la carpeta de trabajo al usuario 'node' no-root
RUN chown -R node:node /app

# Usar el usuario 'node' para ejecutar la aplicación (DevSecOps - Least Privilege)
USER node

# Exponer el puerto del Gateway
EXPOSE 3000

# Ejecutar el código compilado
CMD ["node", "dist/index.js"]